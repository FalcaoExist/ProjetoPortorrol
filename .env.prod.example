# Exemplo de variáveis de ambiente para produção 
# Copie este arquivo para `.env` na raiz do projeto e preencha os valores antes
# de executar o compose de produção.

# Backend
CORS_ORIGINS=https://seu-dominio-frontend.com
SUPABASE_URL=https://seu-projeto-supabase.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role
SECRET_KEY=substitua_por_um_valor_secreto_e_seguro
ALGORITHM=HS256

# Frontend (variáveis de build do Vite)
# Defina para a URL pública onde o backend estará acessível pelo navegador
VITE_API_URL=https://api.seu-dominio.com
VITE_ISDEV=prod

# Opcional: portas (caso altere os padrões)
# FRONTEND_PORT=80
# BACKEND_PORT=8000
